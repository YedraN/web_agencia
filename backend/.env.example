# ── Supabase (PostgreSQL) ──────────────────────────────────────
# Dashboard → Settings → Database → Connection string (Transaction pooler)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Dashboard → Settings → API → anon/public
SUPABASE_ANON_KEY=
# Dashboard → Settings → API → service_role  (NUNCA exponer en frontend)
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# ── JWT ────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://webagencia.vercel.app

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
PORT=8000
FRONTEND_URL=https://webagencia.vercel.app

# ── Email (Resend) ────────────────────────────────────────────────
# https://resend.com → API Keys → Create API Key
RESEND_API_KEY=
# Email remitente (añadir dominio verificado en Resend)
EMAIL_FROM=noreply@webagencia.com
