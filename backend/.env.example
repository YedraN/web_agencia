# Database
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/web_agencia

# JWT
# OBLIGATORIO — genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (separar múltiples orígenes con comas)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_ENV=development
PORT=8000
